<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center" android:padding="32dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Photo &amp; Gallery" android:textSize="26sp" android:textStyle="bold"
        android:layout_marginBottom="48dp"/>

    <Button android:id="@+id/btnCamera"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Take Photo" android:textSize="18sp"
        android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnBrowse"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Browse Folder" android:textSize="18sp"/>

</LinearLayout>